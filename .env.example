# Copy to .env and fill in your real key.
# Default provider is Zhipu GLM-4-Flash (free, accessible from China without VPN).
# Get a key at: https://open.bigmodel.cn/usercenter/proj-mgmt/apikeys
LLM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxx

# Model name (depends on provider)
# Zhipu:    glm-4-flash (free) / glm-4-plus / glm-4-air
# Gemini:   gemini-2.0-flash / gemini-1.5-pro
# Qwen:     qwen-plus / qwen-turbo / qwen-max
# DeepSeek: deepseek-chat
LLM_MODEL=glm-4-flash

# OpenAI-compatible endpoint (depends on provider)
# Zhipu:    https://open.bigmodel.cn/api/paas/v4/
# Gemini:   https://generativelanguage.googleapis.com/v1beta/openai/
# Qwen:     https://dashscope.aliyuncs.com/compatible-mode/v1
# DeepSeek: https://api.deepseek.com/v1
# Moonshot: https://api.moonshot.cn/v1
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# Whisper model (tiny / base / small / medium / large)
WHISPER_MODEL=base
